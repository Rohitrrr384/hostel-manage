{
  "name": "hostelsync-backend",
  "version": "1.0.0",
  "description": "Node.js and MongoDB backend for HostelSync hostel management app.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node src/seed/seed.js",
    "mongo": "mongod --dbpath ./data/db --bind_ip 127.0.0.1 --port 27017",
    "mongo:init": "node src/utils/ensureMongoDataDir.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "nanoid": "^5.0.9"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
